---
layout: layouts/base.njk
---

{% block head %}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  "headline": "{{ title }}",
  "description": "{{ description | default(site.description) }}",
  "author": {
    "@type": "Person",
    "name": "{{ author | default(site.author) | default('Anonymous') }}"
  },
  "publisher": {
    "@type": "Organization",
    "name": "{{ site.organizationName | default(site.title) }}"{% if site.logo %},
    "logo": {
      "@type": "ImageObject",
      "url": "{{ site.url }}{{ site.logo }}"
    }{% endif %}
  },
  "datePublished": "{{ date | dateToRfc3339 }}",
  "dateModified": "{{ date | dateToRfc3339 }}",
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": "{{ site.url }}{{ page.url }}"
  },
  "inLanguage": "{{ lang | default('en') }}"{% if tags %},
  "keywords": "{{ tags | join(', ') }}"{% endif %}{% if category %},
  "articleSection": "{{ category }}"{% endif %}
}
</script>
{% endblock %}

{% set langPrefix = "/" + lang if lang and lang != defaultLanguage else "" %}

<article class="blog-post">
  <div class="blog-container">
    <header class="blog-post-header">
      <p class="blog-post-meta">
        <time datetime="{{ date | isoDate }}">{{ date | dateFormat }}</time>
        {% if author %} &middot; {{ author }}{% endif %}
        {% if category %} &middot; <a href="{{ langPrefix }}/blog/categories/{{ category | slugify }}/">{{ category | capitalize }}</a>{% endif %}
      </p>
      <h1>{{ title }}</h1>
      {% if tags %}
      <div class="blog-post-tags">
        {% for tag in tags %}
        {% if tag != 'post' and tag != 'posts' %}
        <a href="{{ langPrefix }}/blog/tags/{{ tag | slugify }}/" class="tag">{{ tag }}</a>
        {% endif %}
        {% endfor %}
      </div>
      {% endif %}
    </header>

    <div class="blog-post-content">
      {{ content | safe }}
    </div>

    <footer class="blog-post-footer">
      <a href="{{ langPrefix }}/blog/" class="btn">{{ "blog.back" | t(lang) | default("Back to Blog") }}</a>
    </footer>
  </div>
</article>
